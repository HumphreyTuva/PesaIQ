<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:paddingHorizontal="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="32dp">

    <!-- Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="?attr/colorOutlineVariant"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Exclusion Rule"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Transactions matching this keyword will be silently ignored."
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="KEYWORD"
        style="@style/SectionHeader"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. ziidi, international, loan"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_keyword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:textColor="?attr/colorOnSurface"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MATCH TYPE"
        style="@style/SectionHeader"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_contains"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contains"
            android:checkable="true"
            android:checked="true"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_exact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exact match"
            android:checkable="true"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_starts_with"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Starts with"
            android:checkable="true"/>
    </com.google.android.material.chip.ChipGroup>

    <!-- Examples -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/btn_icon_bg"
        android:padding="10dp"
        android:text="@string/exclusion_examples"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:lineSpacingMultiplier="1.4"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel_exclusion"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:layout_marginEnd="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_exclusion"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Add Rule"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>
