<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Transaction Controls"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"/>
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_add_exclusion"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:fabCustomSize="48dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="?attr/colorOnPrimaryContainer"
            app:backgroundTint="?attr/colorPrimaryContainer"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MpesaTracker.Circle"
            android:contentDescription="Add exclusion rule"/>

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Excluded transactions are silently ignored — not saved."
        android:textSize="13sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tv_no_exclusions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="32dp"
        android:text="No exclusion rules yet"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:textSize="14sp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_exclusions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"/>

</LinearLayout>