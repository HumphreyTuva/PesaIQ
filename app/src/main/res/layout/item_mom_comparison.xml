<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Responsive Flow that wraps content to next line if it doesn't fit -->
        <androidx.constraintlayout.helper.widget.Flow
            android:id="@+id/flow_responsive"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:flow_wrapMode="chain"
            app:flow_horizontalStyle="spread_inside"
            app:flow_verticalAlign="top"
            app:flow_horizontalBias="0"
            app:constraint_referenced_ids="layout_left_content,layout_trend"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Info Block: Category and Month Spends -->
        <LinearLayout
            android:id="@+id/layout_left_content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constrainedWidth="true"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/tv_category_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="2"
                tools:text="Food &amp; Groceries" />

            <!-- Nested Flow for Month Spends to handle internal wrapping -->
            <androidx.constraintlayout.helper.widget.Flow
                android:id="@+id/flow_months"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:flow_wrapMode="chain"
                app:flow_horizontalGap="16dp"
                app:flow_horizontalStyle="packed"
                app:flow_horizontalBias="0"
                app:constraint_referenced_ids="tv_month1_info,tv_month2_info" />

            <TextView
                android:id="@+id/tv_month1_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                tools:text="Apr: KSh 3,438.00" />

            <TextView
                android:id="@+id/tv_month2_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="13sp"
                tools:text="Jun: —" />
        </LinearLayout>

        <!-- Trend Block: Icon, Percentage and Difference -->
        <LinearLayout
            android:id="@+id/layout_trend"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical"
            android:minWidth="90dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_trend"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="4dp"
                    app:tint="@color/accent_green"
                    tools:src="@drawable/ic_trending_down"
                    android:contentDescription="Trend Status" />

                <TextView
                    android:id="@+id/tv_percentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_green"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="-100.0%" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_diff_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/accent_green"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="KSh 3,438.00" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
