<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_dark_card">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Appearance &amp; Display"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_white"
        android:layout_marginBottom="24dp"/>

    <!-- Accent color label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Accent Color"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_custom_color"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Custom #HEX"
            android:textColor="@color/brand_orange"
            app:strokeColor="@color/brand_orange"
            android:textSize="12sp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose a preset or enter any hex code"
        android:textSize="12sp"
        android:textColor="@color/text_gray_light"
        android:layout_marginBottom="14dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/color_picker_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider_dark" android:layout_marginTop="20dp" android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Font Style"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_white"/>
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/font_chip_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"/>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/divider_dark" android:layout_marginTop="20dp" android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Theme Mode"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="@color/text_white"/>
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/theme_chip_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"/>

</LinearLayout>