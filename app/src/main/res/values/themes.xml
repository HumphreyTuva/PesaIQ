<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MpesaTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_orange</item>
        <item name="colorSecondary">@color/brand_yellow</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_main</item>
        <item name="android:statusBarColor">@color/bg_main</item>
        <item name="android:navigationBarColor">@color/bg_main</item>
        <item name="android:textColorPrimary">@color/text_main</item>
        <item name="android:textColorSecondary">@color/text_sub</item>
    </style>

    <style name="StatCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card_white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="GlassCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card_white</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">1dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="PurpleButton" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/brand_orange</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="OutlineButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_orange</item>
        <item name="android:textColor">@color/brand_orange</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="SectionHeader">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_muted</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BigNumber">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text_main</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="Theme.MpesaTracker.BottomSheet" parent="Theme.Material3.Light.BottomSheetDialog">
        <item name="android:windowIsFloating">false</item>
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/white</item>
        <item name="shapeAppearanceOverlay">@style/BottomSheetShape</item>
    </style>

    <style name="BottomSheetShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>

    <style name="CustomAlertDialog" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="android:windowBackground">@color/bg_card_white</item>
        <item name="android:textColorPrimary">@color/text_main</item>
    </style>
</resources>
